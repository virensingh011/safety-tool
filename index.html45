<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ResQNet | Disaster Response Optimizer</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #06080d;
      --panel: rgba(13, 18, 30, 0.82);
      --panel-2: rgba(18, 26, 43, 0.74);
      --text: #eff6ff;
      --muted: #9aa8bd;
      --soft: #6f7b8e;
      --line: rgba(190, 210, 255, 0.14);
      --line-strong: rgba(190, 210, 255, 0.25);
      --cyan: #33d6ff;
      --green: #55ffb1;
      --amber: #ffd166;
      --red: #ff647c;
      --violet: #9b87ff;
      --blue: #6aa6ff;
      --radius: 8px;
      --shadow: 0 24px 70px rgba(0, 0, 0, 0.46);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      min-height: 100%;
      background:
        radial-gradient(circle at 15% 14%, rgba(51, 214, 255, 0.18), transparent 28%),
        radial-gradient(circle at 84% 9%, rgba(85, 255, 177, 0.13), transparent 28%),
        radial-gradient(circle at 50% 86%, rgba(255, 100, 124, 0.11), transparent 33%),
        var(--bg);
      color: var(--text);
      overflow: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
      background-size: 42px 42px;
      mask-image: radial-gradient(circle at center, black, transparent 76%);
      animation: gridMove 18s linear infinite;
    }

    body::after {
      content: "";
      position: fixed;
      inset: -25%;
      pointer-events: none;
      background: conic-gradient(from 180deg, transparent, rgba(51, 214, 255, 0.10), transparent, rgba(155, 135, 255, 0.10), transparent);
      filter: blur(80px);
      opacity: 0.9;
      animation: aurora 16s ease-in-out infinite alternate;
    }

    button,
    input,
    select,
    textarea {
      font: inherit;
    }

    button {
      cursor: pointer;
    }

    .app {
      position: relative;
      z-index: 1;
      height: 100vh;
      display: grid;
      grid-template-rows: auto minmax(0, 1fr);
      padding: 14px;
      gap: 14px;
    }

    .topbar,
    .panel,
    .metric,
    .report {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(17, 24, 39, 0.88), rgba(8, 12, 20, 0.76));
      box-shadow: var(--shadow);
      backdrop-filter: blur(22px);
      border-radius: var(--radius);
    }

    .topbar {
      min-height: 76px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 14px 18px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 13px;
      min-width: 0;
    }

    .mark {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      color: #021016;
      font-weight: 950;
      background: linear-gradient(135deg, var(--cyan), var(--green));
      box-shadow: 0 0 28px rgba(51, 214, 255, 0.38);
      animation: pulse 2.4s ease-in-out infinite;
      flex: 0 0 auto;
    }

    h1,
    h2,
    h3,
    p {
      margin-top: 0;
    }

    .brand h1 {
      margin: 0;
      font-size: clamp(1.1rem, 2vw, 1.55rem);
      letter-spacing: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .brand p {
      margin: 3px 0 0;
      color: var(--muted);
      font-size: 0.86rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .top-actions {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .badge {
      border: 1px solid rgba(85, 255, 177, 0.28);
      color: #cbffe9;
      background: rgba(85, 255, 177, 0.08);
      border-radius: 999px;
      padding: 8px 11px;
      font-size: 0.84rem;
      font-weight: 800;
    }

    .ghost,
    .primary {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 10px 12px;
      color: var(--text);
      background: rgba(255, 255, 255, 0.06);
      transition: transform 170ms ease, border 170ms ease, filter 170ms ease;
    }

    .primary {
      border: 0;
      color: #021016;
      background: linear-gradient(135deg, var(--cyan), var(--green));
      font-weight: 900;
      box-shadow: 0 14px 34px rgba(51, 214, 255, 0.23);
    }

    .ghost:hover,
    .primary:hover {
      transform: translateY(-1px);
      border-color: var(--line-strong);
      filter: brightness(1.07);
    }

    .workspace {
      display: grid;
      grid-template-columns: 330px minmax(0, 1fr) 360px;
      gap: 14px;
      min-height: 0;
    }

    .panel {
      min-height: 0;
      overflow: hidden;
    }

    .controls,
    .insights {
      display: flex;
      flex-direction: column;
    }

    .panel-head {
      padding: 16px;
      border-bottom: 1px solid var(--line);
    }

    .panel-head h2 {
      margin: 0;
      font-size: 1rem;
      letter-spacing: 0;
    }

    .panel-head p {
      margin: 5px 0 0;
      color: var(--muted);
      font-size: 0.84rem;
      line-height: 1.45;
    }

    .control-body,
    .insight-body {
      padding: 16px;
      overflow: auto;
    }

    .field {
      display: grid;
      gap: 8px;
      margin-bottom: 15px;
    }

    label {
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 800;
      display: flex;
      justify-content: space-between;
      gap: 12px;
    }

    select,
    input[type="range"] {
      width: 100%;
    }

    select {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: rgba(255, 255, 255, 0.07);
      color: var(--text);
      outline: 0;
      padding: 11px;
    }

    input[type="range"] {
      accent-color: var(--cyan);
    }

    .button-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 18px;
    }

    .legend {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 9px;
      margin-top: 18px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--muted);
      font-size: 0.8rem;
      min-width: 0;
    }

    .dot {
      width: 14px;
      height: 14px;
      border-radius: 4px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      flex: 0 0 auto;
    }

    .terrain-safe { background: rgba(83, 110, 155, 0.35); }
    .terrain-road { background: rgba(106, 166, 255, 0.58); }
    .terrain-water { background: rgba(51, 214, 255, 0.24); }
    .terrain-blocked { background: rgba(255, 100, 124, 0.34); }
    .terrain-shelter { background: rgba(85, 255, 177, 0.58); }
    .terrain-base { background: rgba(255, 209, 102, 0.72); }

    .map-panel {
      position: relative;
      display: grid;
      grid-template-rows: auto minmax(0, 1fr) auto;
    }

    .map-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 16px;
      border-bottom: 1px solid var(--line);
    }

    .map-head h2 {
      margin: 0;
      font-size: 1rem;
    }

    .live {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 800;
    }

    .live::before {
      content: "";
      width: 10px;
      height: 10px;
      border-radius: 99px;
      background: var(--green);
      box-shadow: 0 0 16px var(--green);
      animation: blink 1.4s ease-in-out infinite;
    }

    .map-wrap {
      min-height: 0;
      display: grid;
      place-items: center;
      padding: 16px;
      overflow: hidden;
    }

    .grid {
      width: min(100%, 980px);
      aspect-ratio: 18 / 12;
      display: grid;
      grid-template-columns: repeat(18, 1fr);
      grid-template-rows: repeat(12, 1fr);
      gap: 3px;
      padding: 8px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: rgba(2, 6, 14, 0.66);
      box-shadow: inset 0 0 50px rgba(51, 214, 255, 0.08);
      position: relative;
    }

    .cell {
      border: 1px solid rgba(255, 255, 255, 0.055);
      border-radius: 5px;
      position: relative;
      overflow: hidden;
      transition: transform 150ms ease, box-shadow 150ms ease, border 150ms ease;
    }

    .cell:hover {
      transform: scale(1.08);
      z-index: 3;
      border-color: rgba(255, 255, 255, 0.38);
    }

    .cell.safe { background: rgba(75, 91, 119, 0.34); }
    .cell.road { background: linear-gradient(135deg, rgba(106, 166, 255, 0.64), rgba(106, 166, 255, 0.22)); }
    .cell.water { background: linear-gradient(135deg, rgba(51, 214, 255, 0.28), rgba(51, 214, 255, 0.10)); }
    .cell.blocked { background: linear-gradient(135deg, rgba(255, 100, 124, 0.42), rgba(255, 100, 124, 0.10)); }
    .cell.shelter { background: linear-gradient(135deg, rgba(85, 255, 177, 0.62), rgba(85, 255, 177, 0.14)); }
    .cell.base { background: linear-gradient(135deg, rgba(255, 209, 102, 0.88), rgba(255, 209, 102, 0.22)); }

    .cell.route {
      box-shadow: 0 0 18px rgba(255, 209, 102, 0.54), inset 0 0 18px rgba(255, 209, 102, 0.18);
      border-color: rgba(255, 209, 102, 0.76);
      animation: routePulse 1.1s ease-in-out infinite;
    }

    .cell.hot::after,
    .cell.people::before,
    .cell.base::before,
    .cell.shelter::before {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      font-size: clamp(0.55rem, 1vw, 0.78rem);
      font-weight: 950;
      color: white;
      text-shadow: 0 1px 8px rgba(0, 0, 0, 0.7);
      pointer-events: none;
    }

    .cell.hot::after {
      content: attr(data-risk);
      background: radial-gradient(circle, rgba(255, 100, 124, 0.55), transparent 66%);
    }

    .cell.people::before {
      content: attr(data-people);
    }

    .cell.base::before {
      content: "HQ";
      color: #1a1200;
      text-shadow: none;
    }

    .cell.shelter::before {
      content: "S";
      color: #03140e;
      text-shadow: none;
    }

    .map-footer {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
      padding: 0 16px 16px;
    }

    .metric {
      box-shadow: none;
      background: rgba(255, 255, 255, 0.045);
      padding: 13px;
      min-width: 0;
    }

    .metric small {
      display: block;
      color: var(--muted);
      font-size: 0.76rem;
      font-weight: 800;
      margin-bottom: 8px;
    }

    .metric strong {
      font-size: clamp(1.25rem, 2.6vw, 1.8rem);
      letter-spacing: 0;
    }

    .bar {
      height: 7px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      margin-top: 10px;
      overflow: hidden;
    }

    .bar span {
      display: block;
      height: 100%;
      width: 0%;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--cyan), var(--green));
      transition: width 700ms ease;
    }

    .rank-list {
      display: grid;
      gap: 10px;
      margin-bottom: 16px;
    }

    .rank-item {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 10px;
      align-items: center;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.045);
      border-radius: var(--radius);
      padding: 10px;
    }

    .rank-index {
      width: 30px;
      height: 30px;
      display: grid;
      place-items: center;
      border-radius: 8px;
      background: rgba(51, 214, 255, 0.12);
      color: var(--cyan);
      font-weight: 950;
    }

    .rank-item h3 {
      margin: 0;
      font-size: 0.9rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .rank-item p {
      margin: 3px 0 0;
      color: var(--muted);
      font-size: 0.78rem;
    }

    .score {
      color: var(--amber);
      font-weight: 950;
    }

    .report {
      box-shadow: none;
      background: rgba(255, 255, 255, 0.045);
      padding: 13px;
    }

    .report h3 {
      margin: 0 0 8px;
      font-size: 0.95rem;
    }

    .report p {
      margin: 0;
      color: var(--muted);
      font-size: 0.82rem;
      line-height: 1.55;
    }

    .terminal {
      margin-top: 14px;
      border: 1px solid rgba(51, 214, 255, 0.16);
      background: #050911;
      border-radius: var(--radius);
      overflow: hidden;
    }

    .terminal-head {
      display: flex;
      gap: 6px;
      align-items: center;
      border-bottom: 1px solid var(--line);
      padding: 9px 11px;
    }

    .terminal-head span {
      width: 9px;
      height: 9px;
      border-radius: 99px;
      background: var(--red);
    }

    .terminal-head span:nth-child(2) { background: var(--amber); }
    .terminal-head span:nth-child(3) { background: var(--green); }

    .log {
      height: 190px;
      overflow: auto;
      padding: 12px;
      color: #bff7ff;
      font-family: Consolas, "Courier New", monospace;
      font-size: 0.78rem;
      line-height: 1.55;
      white-space: pre-wrap;
    }

    .project-note {
      border: 1px solid rgba(255, 209, 102, 0.25);
      background: linear-gradient(135deg, rgba(255, 209, 102, 0.10), rgba(255, 255, 255, 0.035));
      border-radius: var(--radius);
      padding: 12px;
      color: #ffe8ad;
      font-size: 0.82rem;
      line-height: 1.5;
      margin-top: 14px;
    }

    @keyframes gridMove {
      to { background-position: 42px 42px; }
    }

    @keyframes aurora {
      from { transform: rotate(0deg) scale(1); }
      to { transform: rotate(9deg) scale(1.08); }
    }

    @keyframes pulse {
      50% { transform: scale(1.05); box-shadow: 0 0 42px rgba(85, 255, 177, 0.42); }
    }

    @keyframes blink {
      50% { opacity: 0.45; transform: scale(1.28); }
    }

    @keyframes routePulse {
      50% { transform: scale(1.045); }
    }

    @media (max-width: 1180px) {
      body {
        overflow: auto;
      }

      .app {
        height: auto;
        min-height: 100vh;
      }

      .workspace {
        grid-template-columns: 310px minmax(0, 1fr);
      }

      .insights {
        grid-column: 1 / -1;
      }
    }

    @media (max-width: 800px) {
      .topbar {
        align-items: flex-start;
        flex-direction: column;
      }

      .top-actions {
        justify-content: flex-start;
      }

      .workspace {
        grid-template-columns: 1fr;
      }

      .map-footer {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 520px) {
      .app {
        padding: 10px;
      }

      .button-grid,
      .legend,
      .map-footer {
        grid-template-columns: 1fr;
      }

      .brand h1 {
        white-space: normal;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <div class="mark">R</div>
        <div>
          <h1>ResQNet: Disaster Response Optimizer</h1>
          <p>One-file humanitarian simulation by Viren Singh</p>
        </div>
      </div>
      <div class="top-actions">
        <span class="badge">GitHub Pages Ready</span>
        <button class="ghost" id="saveBtn" type="button">Save Run</button>
        <button class="primary" id="optimizeTopBtn" type="button">Optimize Plan</button>
      </div>
    </header>

    <main class="workspace">
      <section class="panel controls">
        <div class="panel-head">
          <h2>Mission Controls</h2>
          <p>Model a crisis zone, then let the optimizer prioritize rescue routes by risk, distance, population, and available supplies.</p>
        </div>
        <div class="control-body">
          <div class="field">
            <label for="scenario">Scenario</label>
            <select id="scenario">
              <option value="flood">Monsoon Flood</option>
              <option value="quake">Urban Earthquake</option>
              <option value="heat">Extreme Heat Wave</option>
              <option value="cyclone">Coastal Cyclone</option>
            </select>
          </div>

          <div class="field">
            <label for="teams">Rescue Teams <span id="teamsValue">7</span></label>
            <input id="teams" type="range" min="2" max="14" value="7">
          </div>

          <div class="field">
            <label for="supplies">Medical Supply Units <span id="suppliesValue">420</span></label>
            <input id="supplies" type="range" min="120" max="900" step="20" value="420">
          </div>

          <div class="field">
            <label for="weather">Weather Severity <span id="weatherValue">68%</span></label>
            <input id="weather" type="range" min="10" max="95" value="68">
          </div>

          <div class="field">
            <label for="equity">Equity Priority <span id="equityValue">74%</span></label>
            <input id="equity" type="range" min="0" max="100" value="74">
          </div>

          <div class="button-grid">
            <button class="ghost" id="newScenarioBtn" type="button">New Scenario</button>
            <button class="primary" id="optimizeBtn" type="button">Run Algorithm</button>
            <button class="ghost" id="drillBtn" type="button">Start Drill</button>
            <button class="ghost" id="reportBtn" type="button">Copy Report</button>
          </div>

          <div class="legend">
            <div class="legend-item"><span class="dot terrain-base"></span>Command HQ</div>
            <div class="legend-item"><span class="dot terrain-shelter"></span>Shelter</div>
            <div class="legend-item"><span class="dot terrain-road"></span>Road</div>
            <div class="legend-item"><span class="dot terrain-water"></span>Water/heat zone</div>
            <div class="legend-item"><span class="dot terrain-blocked"></span>Blocked</div>
            <div class="legend-item"><span class="dot terrain-safe"></span>Open zone</div>
          </div>

          <div class="project-note">
            Application framing: present this as an original browser simulation exploring how algorithms can support disaster logistics. Do not claim it is a certified emergency tool.
          </div>
        </div>
      </section>

      <section class="panel map-panel">
        <div class="map-head">
          <h2 id="mapTitle">Monsoon Flood Response Grid</h2>
          <span class="live">Simulation online</span>
        </div>
        <div class="map-wrap">
          <div class="grid" id="grid" aria-label="Disaster response map"></div>
        </div>
        <div class="map-footer">
          <div class="metric">
            <small>Coverage</small>
            <strong id="coverageMetric">0%</strong>
            <div class="bar"><span id="coverageBar"></span></div>
          </div>
          <div class="metric">
            <small>Avg ETA</small>
            <strong id="etaMetric">--m</strong>
            <div class="bar"><span id="etaBar"></span></div>
          </div>
          <div class="metric">
            <small>Risk Reduced</small>
            <strong id="riskMetric">0%</strong>
            <div class="bar"><span id="riskBar"></span></div>
          </div>
          <div class="metric">
            <small>Equity Score</small>
            <strong id="equityMetric">0</strong>
            <div class="bar"><span id="equityBar"></span></div>
          </div>
        </div>
      </section>

      <section class="panel insights">
        <div class="panel-head">
          <h2>Decision Intelligence</h2>
          <p>Priority list, live mission log, and a concise research-style explanation for your project presentation.</p>
        </div>
        <div class="insight-body">
          <div class="rank-list" id="rankList"></div>

          <div class="report">
            <h3>Project Abstract</h3>
            <p id="abstractText">ResQNet is an interactive disaster-response simulator that uses grid search and weighted priority scoring to assign limited rescue capacity to high-risk communities.</p>
          </div>

          <div class="terminal">
            <div class="terminal-head"><span></span><span></span><span></span></div>
            <div class="log" id="log"></div>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script>
    const width = 18;
    const height = 12;
    const totalCells = width * height;
    const gridEl = document.getElementById("grid");
    const scenarioEl = document.getElementById("scenario");
    const teamsEl = document.getElementById("teams");
    const suppliesEl = document.getElementById("supplies");
    const weatherEl = document.getElementById("weather");
    const equityEl = document.getElementById("equity");
    const logEl = document.getElementById("log");
    const rankList = document.getElementById("rankList");
    const mapTitle = document.getElementById("mapTitle");
    const abstractText = document.getElementById("abstractText");

    const labels = {
      flood: "Monsoon Flood Response Grid",
      quake: "Urban Earthquake Response Grid",
      heat: "Extreme Heat Response Grid",
      cyclone: "Coastal Cyclone Response Grid"
    };

    let cells = [];
    let seed = 41;
    let lastPlan = null;

    const terrainCost = {
      safe: 2,
      road: 1,
      water: 6,
      blocked: Infinity,
      shelter: 1,
      base: 1
    };

    function random() {
      seed = (seed * 9301 + 49297) % 233280;
      return seed / 233280;
    }

    function createScenario() {
      seed = Math.floor(Date.now() % 100000);
      const scenario = scenarioEl.value;
      cells = [];
      for (let y = 0; y < height; y++) {
        for (let x = 0; x < width; x++) {
          const edgePressure = x < 3 || y > height - 4 ? 0.12 : 0;
          const noise = random();
          let type = "safe";
          if (noise < 0.13 + edgePressure) type = scenario === "quake" ? "blocked" : "water";
          else if (noise < 0.24) type = "blocked";
          else if (noise < 0.46) type = "road";

          cells.push({
            x,
            y,
            type,
            people: 0,
            risk: 0,
            route: false,
            target: false
          });
        }
      }

      setCell(1, 1, { type: "base" });
      [[15, 2], [4, 9], [14, 9]].forEach(([x, y]) => setCell(x, y, { type: "shelter" }));

      const clusters = scenario === "heat" ? 12 : 10;
      for (let i = 0; i < clusters; i++) {
        const x = 2 + Math.floor(random() * (width - 4));
        const y = 2 + Math.floor(random() * (height - 4));
        const cell = getCell(x, y);
        if (!cell || cell.type === "base" || cell.type === "shelter") continue;
        cell.people = 25 + Math.floor(random() * 180);
        cell.risk = Math.min(99, 28 + Math.floor(random() * 58) + Math.floor(weatherEl.value / 4));
        if (cell.type === "blocked") cell.type = "safe";
      }

      drawGrid();
      resetMetrics();
      writeLog("Scenario generated: " + labels[scenario] + ".");
      writeLog("Field data loaded: roads, shelters, hazards, and population clusters mapped.");
    }

    function getCell(x, y) {
      if (x < 0 || y < 0 || x >= width || y >= height) return null;
      return cells[y * width + x];
    }

    function setCell(x, y, patch) {
      Object.assign(getCell(x, y), patch);
    }

    function drawGrid() {
      gridEl.innerHTML = "";
      cells.forEach((cell, index) => {
        const div = document.createElement("div");
        div.className = "cell " + cell.type;
        if (cell.route) div.classList.add("route");
        if (cell.people > 0) div.classList.add("people");
        if (cell.risk > 58) div.classList.add("hot");
        div.dataset.index = index;
        div.dataset.people = cell.people ? cell.people : "";
        div.dataset.risk = cell.risk ? cell.risk : "";
        div.title = cellLabel(cell);
        gridEl.appendChild(div);
      });
      mapTitle.textContent = labels[scenarioEl.value];
    }

    function cellLabel(cell) {
      const parts = ["x:" + cell.x, "y:" + cell.y, cell.type];
      if (cell.people) parts.push(cell.people + " people");
      if (cell.risk) parts.push("risk " + cell.risk);
      return parts.join(" | ");
    }

    function optimize() {
      cells.forEach(cell => {
        cell.route = false;
        cell.target = false;
      });

      const base = getCell(1, 1);
      const communities = cells.filter(cell => cell.people > 0);
      const plans = communities.map(cell => {
        const path = shortestPath(base, cell);
        const distance = path.length ? path.length : 999;
        const vulnerability = cell.people * (cell.risk / 100);
        const equityBoost = 1 + (Number(equityEl.value) / 100) * (cell.people > 100 ? 0.45 : 0.18);
        const score = Math.round((vulnerability * equityBoost * 100) / Math.pow(distance + 4, 1.08));
        return { cell, path, distance, score, vulnerability };
      }).filter(plan => plan.path.length > 0)
        .sort((a, b) => b.score - a.score);

      const teams = Number(teamsEl.value);
      const supplies = Number(suppliesEl.value);
      const selected = plans.slice(0, teams);
      let usedSupplies = 0;
      let reachedPeople = 0;
      let reducedRisk = 0;
      let etaSum = 0;

      selected.forEach((plan, i) => {
        const allocation = Math.min(plan.cell.people, Math.floor(supplies / Math.max(teams, 1)));
        usedSupplies += allocation;
        reachedPeople += Math.min(plan.cell.people, allocation);
        reducedRisk += plan.cell.risk * (allocation / Math.max(plan.cell.people, 1));
        etaSum += plan.distance * (scenarioEl.value === "flood" ? 5 : 4);
        plan.path.forEach(cell => cell.route = true);
        plan.cell.target = true;
        window.setTimeout(() => drawGrid(), i * 75);
      });

      const totalPeople = communities.reduce((sum, cell) => sum + cell.people, 0);
      const coverage = totalPeople ? Math.round((reachedPeople / totalPeople) * 100) : 0;
      const eta = selected.length ? Math.round(etaSum / selected.length) : 0;
      const risk = Math.min(99, Math.round(reducedRisk / Math.max(selected.length, 1)));
      const equityScore = Math.min(100, Math.round((coverage * 0.58) + (Number(equityEl.value) * 0.28) + (Math.max(0, 100 - eta) * 0.14)));

      lastPlan = { selected, coverage, eta, risk, equityScore, usedSupplies, totalPeople, reachedPeople };
      updateMetrics(lastPlan);
      renderRanks(plans);
      drawGrid();
      writeLog("Optimization complete: " + selected.length + " routes selected.");
      writeLog("Coverage " + coverage + "% | Avg ETA " + eta + "m | Risk reduction " + risk + "%.");
      updateAbstract();
    }

    function shortestPath(start, goal) {
      const distances = new Map();
      const previous = new Map();
      const queue = [];
      cells.forEach(cell => distances.set(key(cell), Infinity));
      distances.set(key(start), 0);
      queue.push(start);

      while (queue.length) {
        queue.sort((a, b) => distances.get(key(a)) - distances.get(key(b)));
        const current = queue.shift();
        if (current === goal) break;

        neighbors(current).forEach(next => {
          const cost = terrainCost[next.type];
          if (!Number.isFinite(cost)) return;
          const weatherPenalty = next.type === "water" ? Number(weatherEl.value) / 28 : 0;
          const riskPenalty = next.risk ? next.risk / 35 : 0;
          const alt = distances.get(key(current)) + cost + weatherPenalty + riskPenalty;
          if (alt < distances.get(key(next))) {
            distances.set(key(next), alt);
            previous.set(key(next), current);
            if (!queue.includes(next)) queue.push(next);
          }
        });
      }

      const path = [];
      let current = goal;
      while (current && current !== start) {
        path.unshift(current);
        current = previous.get(key(current));
      }
      if (current === start) path.unshift(start);
      return path.length > 1 ? path : [];
    }

    function neighbors(cell) {
      return [
        getCell(cell.x + 1, cell.y),
        getCell(cell.x - 1, cell.y),
        getCell(cell.x, cell.y + 1),
        getCell(cell.x, cell.y - 1)
      ].filter(Boolean);
    }

    function key(cell) {
      return cell.x + "," + cell.y;
    }

    function updateMetrics(plan) {
      setMetric("coverage", plan.coverage, "%", plan.coverage);
      setMetric("eta", plan.eta, "m", Math.max(0, 100 - plan.eta));
      setMetric("risk", plan.risk, "%", plan.risk);
      setMetric("equity", plan.equityScore, "", plan.equityScore);
    }

    function setMetric(name, value, suffix, bar) {
      document.getElementById(name + "Metric").textContent = value + suffix;
      document.getElementById(name + "Bar").style.width = Math.max(0, Math.min(100, bar)) + "%";
    }

    function resetMetrics() {
      setMetric("coverage", 0, "%", 0);
      setMetric("eta", "--", "m", 0);
      setMetric("risk", 0, "%", 0);
      setMetric("equity", 0, "", 0);
      rankList.innerHTML = "";
      lastPlan = null;
    }

    function renderRanks(plans) {
      rankList.innerHTML = "";
      plans.slice(0, 5).forEach((plan, index) => {
        const item = document.createElement("div");
        item.className = "rank-item";
        item.innerHTML = `
          <div class="rank-index">${index + 1}</div>
          <div>
            <h3>Sector ${plan.cell.x}-${plan.cell.y}</h3>
            <p>${plan.cell.people} people | risk ${plan.cell.risk} | route ${plan.distance} cells</p>
          </div>
          <div class="score">${plan.score}</div>
        `;
        rankList.appendChild(item);
      });
    }

    function startDrill() {
      optimize();
      let step = 0;
      const updates = [
        "NCC-style command drill started.",
        "Team Alpha dispatched toward highest-priority sector.",
        "Medical supplies staged at nearest shelter.",
        "Blocked roads flagged for rerouting.",
        "Civilian evacuation wave simulated.",
        "Drill complete. Review metrics and written abstract."
      ];
      const timer = window.setInterval(() => {
        writeLog(updates[step]);
        step++;
        if (step >= updates.length) window.clearInterval(timer);
      }, 650);
    }

    function updateAbstract() {
      if (!lastPlan) return;
      abstractText.textContent = "ResQNet models disaster logistics on a weighted grid. It applies Dijkstra-style pathfinding and vulnerability scoring to prioritize limited rescue teams. In this run, the system reached " + lastPlan.coverage + "% coverage, estimated " + lastPlan.eta + " minute average arrival, and produced an equity score of " + lastPlan.equityScore + ". The project demonstrates how computational thinking can support humanitarian response planning while remaining transparent about its prototype status.";
    }

    function buildReport() {
      if (!lastPlan) optimize();
      const scenario = labels[scenarioEl.value];
      return [
        "ResQNet: Disaster Response Optimizer",
        "Created by Viren Singh",
        "",
        "Project summary:",
        "ResQNet is a browser-based humanitarian logistics simulator. It uses grid-based pathfinding and priority scoring to allocate limited rescue teams and medical supplies during a crisis scenario.",
        "",
        "Scenario: " + scenario,
        "Rescue teams: " + teamsEl.value,
        "Medical supply units: " + suppliesEl.value,
        "Weather severity: " + weatherEl.value + "%",
        "Equity priority: " + equityEl.value + "%",
        "",
        "Run results:",
        "Coverage: " + lastPlan.coverage + "%",
        "Average ETA: " + lastPlan.eta + " minutes",
        "Risk reduced: " + lastPlan.risk + "%",
        "Equity score: " + lastPlan.equityScore,
        "",
        "Academic explanation:",
        "The optimizer uses Dijkstra-style shortest path search where terrain and weather change traversal cost. Communities are ranked by a weighted score that combines population, hazard risk, path distance, and an equity factor. The result is not a real emergency tool, but a transparent prototype showing algorithmic reasoning for disaster response.",
        "",
        "Possible extensions:",
        "Add real geospatial data, connect live weather APIs, validate allocation logic with field experts, and compare algorithmic recommendations against human-led plans."
      ].join("\\n");
    }

    async function copyReport() {
      const report = buildReport();
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(report);
      } else {
        const temp = document.createElement("textarea");
        temp.value = report;
        temp.style.position = "fixed";
        temp.style.opacity = "0";
        document.body.appendChild(temp);
        temp.select();
        document.execCommand("copy");
        temp.remove();
      }
      writeLog("Presentation report copied to clipboard.");
    }

    function saveRun() {
      if (!lastPlan) optimize();
      const runs = JSON.parse(localStorage.getItem("resqnet-runs") || "[]");
      runs.unshift({
        time: new Date().toLocaleString(),
        scenario: scenarioEl.value,
        coverage: lastPlan.coverage,
        eta: lastPlan.eta,
        equity: lastPlan.equityScore
      });
      localStorage.setItem("resqnet-runs", JSON.stringify(runs.slice(0, 8)));
      writeLog("Run saved locally. Saved runs: " + Math.min(runs.length, 8) + ".");
    }

    function writeLog(message) {
      const time = new Date().toLocaleTimeString([], { hour: "2-digit", minute: "2-digit", second: "2-digit" });
      logEl.textContent += "[" + time + "] " + message + "\\n";
      logEl.scrollTop = logEl.scrollHeight;
    }

    function syncLabels() {
      document.getElementById("teamsValue").textContent = teamsEl.value;
      document.getElementById("suppliesValue").textContent = suppliesEl.value;
      document.getElementById("weatherValue").textContent = weatherEl.value + "%";
      document.getElementById("equityValue").textContent = equityEl.value + "%";
    }

    [teamsEl, suppliesEl, weatherEl, equityEl].forEach(input => {
      input.addEventListener("input", syncLabels);
      input.addEventListener("change", () => {
        syncLabels();
        writeLog("Parameter updated. Run the optimizer to recalculate.");
      });
    });

    scenarioEl.addEventListener("change", createScenario);
    document.getElementById("newScenarioBtn").addEventListener("click", createScenario);
    document.getElementById("optimizeBtn").addEventListener("click", optimize);
    document.getElementById("optimizeTopBtn").addEventListener("click", optimize);
    document.getElementById("drillBtn").addEventListener("click", startDrill);
    document.getElementById("reportBtn").addEventListener("click", copyReport);
    document.getElementById("saveBtn").addEventListener("click", saveRun);

    syncLabels();
    createScenario();
    window.setTimeout(optimize, 550);
  </script>
</body>
</html>
